# LitPlay root/backend environment example
NODE_ENV=development
LOG_LEVEL=info

# Auth/JWT (production: 32+ random bytes, from Secrets Manager)
JWT_ACCESS_SECRET=replace-with-32-byte-minimum-secret
JWT_REFRESH_SECRET=replace-with-32-byte-minimum-secret
GOOGLE_OAUTH_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

# Service databases
DATABASE_URL=postgres://litplay:devpassword@localhost:5432/auth_db
AUTH_DATABASE_URL=postgres://litplay:devpassword@localhost:5432/auth_db
PROGRESS_DATABASE_URL=postgres://litplay:devpassword@localhost:5433/progress_db
CONTENT_DATABASE_URL=postgres://litplay:devpassword@localhost:5434/content_db
CLASSROOM_DATABASE_URL=postgres://litplay:devpassword@localhost:5435/classroom_db
NOTIFICATION_DATABASE_URL=postgres://litplay:devpassword@localhost:5436/notification_db

# Shared infra
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:9092
INTERNAL_SERVICE_TOKEN=replace-with-internal-service-jwt

# ASR
ASR_AUTH_REQUIRED=false
WHISPER_GPU_ENABLED=false
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=eastus
AZURE_SPEECH_LANGUAGE=en-US

# Content signing
CLOUDFRONT_KEY_PAIR_ID=
CLOUDFRONT_PRIVATE_KEY=

# Push/email providers
FCM_PROJECT_ID=
FCM_CLIENT_EMAIL=
FCM_PRIVATE_KEY=
# Optional short-lived dev override; production should use service account exchange
FCM_ACCESS_TOKEN=
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_BUNDLE_ID=
APNS_PRIVATE_KEY=
APNS_USE_SANDBOX=true
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=no-reply@litplay.app
SENDGRID_TEST_TO_EMAIL=

# Analytics
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
